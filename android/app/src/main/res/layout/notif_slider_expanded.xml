<?xml version="1.0" encoding="utf-8"?>
<!-- Expanded layout (doc §6.3): compact row + preset chips + stream label.
     Preset taps are the "slider-like" affordance. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btn_mute"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:contentDescription="@string/notif_mute" />

        <TextView
            android:id="@+id/btn_down"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="@string/notif_minus"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/volume_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:max="100" />

        <TextView
            android:id="@+id/btn_up"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="@string/notif_plus"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/volume_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="42dp"
            android:gravity="end"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/preset_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/preset_0"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/notif_preset_0"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/preset_25"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/notif_preset_25"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/preset_50"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/notif_preset_50"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/preset_75"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/notif_preset_75"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/preset_100"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/notif_preset_100"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/stream_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:textSize="12sp" />
</LinearLayout>
